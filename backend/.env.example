APP_NAME=Whagent Backend
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg://car_agent_user:car_agent_password@whagent-postgres:5432/car_agent_db

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

INTERNAL_API_KEY=change-me

OPENAI_API_KEY=
DEFAULT_OPENAI_MODEL=gpt-4.1-mini
AI_RUNTIME_ENABLED=true

EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
WEBHOOK_PUBLIC_BASE_URL=https://api-whagent.pinottiautomacoes.online

CRM_MOCK_BASE_URL=http://whagent-crm-mock:8001

REDIS_URL=redis://whagent-redis:6379/0
AGENT_DEBOUNCE_SECONDS=8
CONVERSATION_LOCK_SECONDS=60

DEBUG_ALLOW_FROM_ME_AS_INBOUND=false
CORS_ORIGINS=http://localhost:3000,https://whagent.pinottiautomacoes.online

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
