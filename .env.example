# ===== Whagent (Docker Swarm) =====
# Copie para .env e ajuste os valores.
APP_NAME=Whagent Backend
APP_ENV=production
APP_DEBUG=false

# --- Banco principal ---
POSTGRES_DB=car_agent_db
POSTGRES_USER=car_agent_user
POSTGRES_PASSWORD=car_agent_password_change_me
DATABASE_URL=postgresql+psycopg://car_agent_user:car_agent_password_change_me@postgres:5432/car_agent_db

# --- Auth backend ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
INTERNAL_API_KEY=change-me-internal-api-key

# --- OpenAI ---
OPENAI_API_KEY=
DEFAULT_OPENAI_MODEL=gpt-4.1-mini
AI_RUNTIME_ENABLED=true

# --- Integrações ---
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
WEBHOOK_PUBLIC_BASE_URL=https://api.seu-dominio.com
CRM_MOCK_BASE_URL=http://crm-mock:8001

# --- Redis / worker ---
REDIS_URL=redis://redis:6379/0
AGENT_DEBOUNCE_SECONDS=8
CONVERSATION_LOCK_SECONDS=60
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_BATCH_SIZE=10

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=https://api.seu-dominio.com
CORS_ORIGINS=https://app.seu-dominio.com

# --- Traefik / domínio (docker-stack.yml) ---
# Opcional: se não definir, o stack usa os defaults do arquivo YAML.
TRAEFIK_DOCKER_NETWORK=PinottiNet
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencryptresolver
APP_DOMAIN=app.seu-dominio.com
API_DOMAIN=api.seu-dominio.com

# --- Debug / admin bootstrap ---
DEBUG_ALLOW_FROM_ME_AS_INBOUND=false
ADMIN_EMAIL=admin@seu-dominio.com
ADMIN_PASSWORD=trocar-esta-senha-forte

# Worker -> backend interno
BACKEND_INTERNAL_API_URL=http://backend:8000
BACKEND_INTERNAL_API_KEY=change-me-internal-api-key
